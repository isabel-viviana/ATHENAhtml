{
  "config": {
    "app": {
      "nombre": "diseñoATHENA",
      "version": "1.0.0",
      "descripcion": "Plataforma de preparación educativa con IA"
    },
    "api": {
      "url": "https://api.disenoathena.com",
      "timeout": 30000,
      "version": "v1"
    },
    "autenticacion": {
      "tokenExpiration": 3600,
      "refreshTokenExpiration": 604800,
      "metodos": ["email", "google", "github"]
    },
    "suscripcion": {
      "planes": [
        {
          "id": "basico",
          "nombre": "Básico",
          "precio": 0,
          "caracteristicas": ["Acceso limitado", "10 tests/mes", "Sin certificados"]
        },
        {
          "id": "pro",
          "nombre": "Pro",
          "precio": 9.99,
          "caracteristicas": ["Acceso completo", "100 tests/mes", "Certificados", "Tutor IA"]
        },
        {
          "id": "premium",
          "nombre": "Premium",
          "precio": 19.99,
          "caracteristicas": ["Acceso ilimitado", "Tests ilimitados", "Certificados", "Tutor IA 24/7", "Soporte prioritario"]
        }
      ]
    },
    "notificaciones": {
      "habilitadas": true,
      "tiempoRespuesta": 5000
    },
    "seguridad": {
      "https": true,
      "cors": ["https://disenoathena.com", "https://admin.disenoathena.com"],
      "rateLimiting": {
        "enabled": true,
        "requests": 100,
        "window": 900000
      }
    }
  }
}
